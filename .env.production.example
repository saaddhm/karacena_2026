# ===== Karacena 2026 — production VPS =====
PORT=5000
NODE_ENV=production

# URL publique du site (redirections CMI + CORS). UNE seule origine, la vraie.
CLIENT_URL=https://karacena.ma
# URL publique de l'API (callbacks CMI serveur→serveur — DOIT être joignable par CMI)
API_URL=https://karacena.ma

# MySQL (local au VPS)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=karacena_2026
DB_USER=karacena
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Auth — OBLIGATOIRE : générer une vraie clé (openssl rand -hex 64)
JWT_SECRET=CHANGE_ME_64_RANDOM_HEX_CHARS
JWT_EXPIRES_IN=12h

# Admin bootstrap (premier seed uniquement)
ADMIN_EMAIL=admin@karacena.ma
ADMIN_PASSWORD=CHANGE_ME

# Uploads
UPLOAD_DIR=uploads
MAX_UPLOAD_MB=25

# Paiement CMI — identifiants de PRODUCTION fournis par le CMI
CMI_MERCHANT_ID=
CMI_STORE_KEY=
CMI_GATEWAY_URL=https://payment.cmi.co.ma/fim/est3Dgate
